# =============================================================================
# FL Gateway Environment Variables — REQUIRED before starting any service
# =============================================================================

# The shared secret used for:
#   - JWT signing (HS256)
#   - Fernet encryption key derivation (PBKDF2-SHA256)
# Must be at least 32 random characters. Example generation:
#   python -c "import secrets; print(secrets.token_hex(32))"
FL_GATEWAY_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_HERE

# Password for the seeded admin account (used on FIRST startup only)
# After first startup, the hash is stored in the DB — this env var only
# needs to match on the very first run.
ADMIN_SEED_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_HERE
